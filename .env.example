# ===== Database (Supabase) =====
# Supabase の「接続文字列 (URI)」をそのまま入れる。
# 例: postgresql://backup_cleanup:YOUR_PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require
POSTGRES_URL=postgresql://backup_cleanup:YOUR_PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# （任意）アプリ側から Supabase REST/Realtime を叩く場合にだけ使用
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY


# ===== Storage (R2 for images) =====
# ※ コード上は "R2_TEMP_*" を見ているので、ここもそれに合わせる
R2_TEMP_BUCKET_NAME=your-bucket
R2_TEMP_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_TEMP_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY
R2_TEMP_SECRET_ACCESS_KEY=YOUR_R2_SECRET_KEY


# ===== Backup (DB & Images) =====
# 年別DBのファイル名テンプレート（実体は *_YYYY.db で生成）
# 例: artifacts/backup/jyogi_sns_backup_2026.db
# ここを artifacts/ 以下にしておくと、.gitignore で artifacts/ を丸ごと無視できて楽です
BACKUP_DB_PATH=artifacts/backup/jyogi_sns_backup.db

# 「何日前より前を削除＆バックアップ対象にするか」(日数)
BACKUP_THRESHOLD_DAYS=90

# 画像一時保存ディレクトリ（既定: artifacts/images）
BACKUP_IMAGES_DIR=artifacts/images

# マニフェスト(JSON)の出力先（既定: artifacts/backup_manifest.json）
BACKUP_MANIFEST_PATH=artifacts/backup_manifest.json


# ===== Delete Guard (本番削除の安全装置) =====
# デフォルトは DRY-RUN（実際には削除しない）
VERIFY_ONLY=true
DELETE_ENABLED=false

# 復元テスト成功マーカー
RESTORE_OK_MARKER=artifacts/restore_smoke_test.ok

# 削除対象プラン(delete_plan.json) のパス
DELETE_PLAN_PATH=artifacts/delete_plan.json


# ===== Raspberry Pi (デプロイ用に使うなら任意) =====
PI_SSH_HOST=192.168.x.x
PI_SSH_USER=pi
PI_SSH_KEY_PATH=/path/to/private/key


# ===== Infra Logging (任意) =====
# infrastructure_logs 用の接続先。
# 未設定なら POSTGRES_URL を使う。どちらも未設定ならロギングはスキップされる。
INFRA_LOG_DB_URL=postgresql://backup_cleanup:YOUR_PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# ログ上で環境を識別するための値（例: prod / staging / local など）
INFRA_ENVIRONMENT=prod